# ---- Supabase ----
# URL del proyecto (Settings → API). Pública, puede ir al cliente.
NEXT_PUBLIC_SUPABASE_URL=
# Service role key (Settings → API). SECRETA. Solo servidor. Bypassa RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ---- API de momios ----
# Recomendado: SportsGameOdds (incluye Pinnacle como ancla sharp).
# Confirma endpoints y precios vigentes en la doc del proveedor antes de integrar.
ODDS_API_KEY=
ODDS_API_BASE_URL=

# ---- Gate de un solo usuario ----
# Contraseña simple para entrar al dashboard.
APP_PASSWORD=

# ---- Cron (Vercel) ----
# Secreto para que solo el cron pueda llamar /api/scan.
CRON_SECRET=
